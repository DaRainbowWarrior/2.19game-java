<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="555.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="twonineteengame.ui.StartController">
   <children>
      <VBox alignment="CENTER" prefHeight="680.0" prefWidth="600.0" spacing="80.0">
         <children>
            <Label prefHeight="93.0" prefWidth="332.0" text="2.19 Game" textAlignment="CENTER">
               <font>
                  <Font size="64.0" />
               </font>
            </Label>
            <HBox alignment="CENTER" prefHeight="149.0" prefWidth="600.0" spacing="130.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="149.0" prefWidth="140.0">
                     <children>
                        <Label text="Red Player" textFill="RED">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Label>
                        <TextField fx:id="redPlayerName" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="149.0" prefWidth="157.0">
                     <children>
                        <Label prefHeight="32.0" prefWidth="116.0" text="Blue Player" textAlignment="CENTER" textFill="#2600ff">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Label>
                        <TextField fx:id="bluePlayerName" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="80.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onStartGameButton" text="Start Game">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#onLoadScoreboardButton" text="Load Scoreboard">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
